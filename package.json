{
  "name": "youtalk-blog",
  "version": "1.0.0",
  "description": "Статическая адаптивная верстка двух страниц по макету YouTalk. Сессионное задание по предмету Основы frontend-разработки.",
  "main": "index.js",
  "scripts": {
    "check:html": "htmlhint \"*.html\"",
    "check:css": "stylelint \"css/**/*.css\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "check": "npm run check:html && npm run check:css && npm run format:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vkuryndin/FrontendCSSPractice.git"
  },
