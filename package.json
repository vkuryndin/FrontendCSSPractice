  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vkuryndin/FrontendCSSPractice/issues"
  },
  "homepage": "https://github.com/vkuryndin/FrontendCSSPractice#readme",
  "devDependencies": {
    "htmlhint": "^1.9.2",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
